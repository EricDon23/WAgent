# Writing Agent - 环境配置文件
# 复制此文件为 .env 并填入实际值

# ==================== 导演AI配置 ====================
# 默认模型提供商 (openai, bytedance, baidu, alibaba, anthropic, deepseek)
DEFAULT_MODEL_PROVIDER=openai

# ==================== AI模型配置 ====================
# 通义千问API Key (必填)
DASHSCOPE_API_KEY=your_api_key_here

# 模型基础地址
MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 默认模型名称
MODEL_NAME=qwen-plus

# ==================== OpenAI配置 ====================
# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI API基础地址
OPENAI_BASE_URL=https://api.openai.com/v1

# ==================== 字节跳动配置 ====================
# 字节跳动API Key
BYTEDANCE_API_KEY=your_bytedance_api_key_here

# 字节跳动API基础地址
BYTEDANCE_BASE_URL=https://api.bytedance.com/v1

# ==================== 百度配置 ====================
# 百度API Key
BAIDU_API_KEY=your_baidu_api_key_here

# 百度Secret Key
BAIDU_SECRET_KEY=your_baidu_secret_key_here

# ==================== 存储路径配置 ====================
# 日志目录
LOG_DIR=logs

# 模板目录
TEMPLATE_DIR=templates

# 数据目录
DATA_DIR=data

# ==================== 程序运行参数 ====================
# 最大文本长度（字符）
MAX_TEXT_LENGTH=2000

# 默认语气: formal(正式), casual(口语), academic(学术)
DEFAULT_TONE=formal

# 请求超时时间（秒）
REQUEST_TIMEOUT=30

# ==================== 日志配置 ====================
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 日志保留天数
LOG_RETENTION_DAYS=30
